{
  "license": "ISC",
  "scripts": {
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check",
    "drift:bench": "yarn ts-mocha -p ./tsconfig.json -t 300000 benchmark/drift/benchmark.ts",
    "openbook:bench": "yarn ts-mocha -p ./tsconfig.json -t 1800000 benchmark/openbook/benchmark.ts",
    "raydium:bench": "yarn ts-mocha -p ./tsconfig.json -t 1800000 benchmark/raydium/benchmark.ts",
    "meteora:bench": "yarn ts-mocha -p ./tsconfig.json -t 1800000 benchmark/meteora/benchmark.ts",
    "orca:bench": "yarn ts-mocha -p ./tsconfig.json -t 1800000 benchmark/orca/benchmark.ts",
    "marginfi:bench": "yarn ts-mocha -p ./tsconfig.json -t 1800000 benchmark/marginfi/benchmark.ts",
    "kamino:bench": "yarn ts-mocha -p ./tsconfig.json -t 1800000 benchmark/kamino/benchmark.ts",
    "demo": "ts-node --transpile-only demo/run.ts",
    "demo:setup": "ts-node --transpile-only demo/run.ts setup",
    "demo:read": "ts-node --transpile-only demo/run.ts read",
    "demo:local": "CLUSTER=local ts-node --transpile-only demo/run.ts",
    "demo:local:setup": "CLUSTER=local ts-node --transpile-only demo/run.ts setup",
    "demo:local:read": "CLUSTER=local ts-node --transpile-only demo/run.ts read"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "prettier": "^2.6.2",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
